{% extends "layout.jinja2" %}

{% block title %}Detalles del Cuadro{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>{{ cuadro.name }}</h2>
    {% if request.authenticated_userid==cuadro.autor.id or request.user.name == 'Admin' %}
    <div>
        <a href="{{ request.route_url('edit_cuadro', id=cuadro.id) }}" class="btn btn-warning">Editar</a>
        <form method="post" action="{{ request.route_url('delete_cuadro', id=cuadro.id) }}" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este cuadro?');" style="display:inline;">
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </form>
    </div>
    {% endif %}
</div>
<div class="card mb-4 shadow-sm">
    <img src="{{ cuadro.url_imagen }}" class="card-img-top img-detalle-full" alt="{{ cuadro.name }}">
    <div class="card-body">
        <p class="card-text">{{ cuadro.description }}</p>
        <ul class="list-group list-group-flush">
            <li class="list-group-item"><strong>Autor:</strong> {{ cuadro.autor.name }}</li>
            <li class="list-group-item"><strong>En Venta:</strong> {{ 'Sí' if cuadro.enVenta else 'No' }}</li>
            {% if cuadro.precio %} 
            <li class="list-group-item"><strong>Precio:</strong> ${{ cuadro.precio }}</li>
            {% endif %}
        </ul>
        <div class="mt-3 d-flex justify-content-between">
            <a href="{{ request.route_url('cuadros_autor', id=cuadro.autor.id) }}" class="btn btn-secondary">Ver más cuadros de {{ cuadro.autor.name }}</a>
            <a href="{{ request.route_url('home') }}" class="btn btn-secondary mt-3">Volver a la Galería</a>
        </div>
    </div>
        
</div>


{% endblock %}