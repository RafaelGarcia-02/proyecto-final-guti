{% extends "layout.jinja2" %}

{% block title %}Cuadros{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Galeria de Arte</h2>
    <form class="d-flex" method="get" action="{{ request.route_url('home') }}">
        <input class="form-control me-2" type="search" placeholder="Buscar cuadros..." aria-label="Search" name="a" value="{{ request.params.get('a', '') }}">
        <button class="btn btn-outline-success" type="submit">Buscar</button>
    </form>
</div>

<div class="row">
        {% for cuadro in cuadros %}
        <div class="col-md-4 mb-4"> <div class="card h-100 shadow-sm">
                <img src="{{ cuadro.url_imagen }}" class="card-img-top card-img-custom" alt="{{ cuadro.name }}">
                
                <div class="card-body">
                    <h5 class="card-title">{{ cuadro.name }}</h5>

                    <p class="card-text">{{ cuadro.less_description[:100] }}...</p>
                </div>
                
                <div class="card-footer bg-transparent border-top-0">
                    <a href="/cuadros/{{ cuadro.id }}" class="btn btn-primary w-100">Ver mas detalles</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
   
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Autores</h2>
    <form class="d-flex" method="get" action="{{ request.route_url('home') }}">
        <input class="form-control me-2" type="search" placeholder="Buscar autores..." aria-label="Search" name="q" value="{{ request.params.get('q', '') }}">
        <button class="btn btn-outline-success" type="submit">Buscar</button>
    </form>
</div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Ver Cuadros</th>
                {% if request.authenticated_userid and request.user.name == 'Admin' %}
                <th>Editar</th>
                {% endif %}
                {% if request.authenticated_userid and request.user.name == 'Admin' %}
                <th>Eliminar</th>
                {% endif %}
            </tr>
        </thead>
        <tbody>
            {% for autor in autores %}
            {%if autor.name != 'Admin' %}
            {%if autor.name != request.user.name %}
            <tr>
                <td>{{ autor.name }}</td>
                <td><a href="{{ request.route_url('cuadros_autor', id=autor.id) }}" class="btn btn-secondary">Ver Cuadros</a></td>
                {% if request.authenticated_userid and request.user.name == 'Admin' %}
                <td><a href="{{ request.route_url('edit_autor', id=autor.id) }}" class="btn btn-warning">Editar</a></td>
                {% endif %}
                {% if request.authenticated_userid and request.user.name == 'Admin' %}
                <td>
                    <form method="post" action="{{ request.route_url('delete_autor', id=autor.id) }}" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este autor?');">
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                    </form>
                </td>
                {% endif %}
            </tr>
            {% endif %}
            {% endif %}
            {% endfor %}
        </tbody>


{% endblock %}