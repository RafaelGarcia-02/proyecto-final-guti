<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Mi Exposición{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link rel="stylesheet" href="{{ request.static_url('myapp:static/style.css') }}">
</head>
<body>

    <nav class="navbar navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="{{ request.route_url('home') }}">Exposición de cuadros online</a>
        
        <div class="d-flex align-items-center">
            {% if request.authenticated_userid %}
                <span class="navbar-text text-light me-3">Bienvenido, {{ request.user.name }}</span>
                {% if request.user.role == 'admin' %}
                <a href="{{ request.route_url('admin') }}" class="btn btn-outline-warning me-2">Panel Admin</a>
                {% else %}
                <a href="{{ request.route_url('add_cuadro') }}" class="btn btn-outline-light me-2">Pintar nuevo cuadro</a>
                {% endif %}
                <a href="{{ request.route_url('logout') }}" class="btn btn-outline-danger btn-sm">Cerrar sesión</a>
            {% else %}
                <a href="{{ request.route_url('login') }}" class="btn btn-outline-light me-2">Iniciar sesión</a>
                <a href="{{ request.route_url('register') }}" class="btn btn-outline-light">Registrarse</a>
            {% endif %}

          
        </div>
      </div>
    </nav>

    <div class="container mt-4">
        {% block content %}{% endblock %}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>